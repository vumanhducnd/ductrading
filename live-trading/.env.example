# Copy file này thành .env và điền thông tin thực
# cp .env.example .env

# TikTok username (có @ ở đầu)
TIKTOK_USERNAME=@your_tiktok_username

# Thời gian hiển thị mỗi mã (giây)
INTERVAL_SECONDS=30

# Port cho overlay web
OVERLAY_PORT=5000

# Keyword tìm cửa sổ TradingView app (tìm partial match trong window title)
# TradingView app có title dạng: "VNM ▼ 70,000 -1.2% / YourUsername"
# → Đặt = username TradingView của bạn (phần sau dấu /)
# Chạy "python find_windows.py" để xem title thực tế
TRADINGVIEW_WINDOW_TITLE=VuManhDuc

# Số lượng mã tối đa trong queue
MAX_QUEUE_SIZE=20

# Demo mode: true = tự thêm mã ngẫu nhiên (không cần TikTok live)
DEMO_MODE=false
DEMO_INTERVAL_SECONDS=5

# File log
LOG_FILE=trading.log
